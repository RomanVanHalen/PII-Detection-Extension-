{
  "manifest_version": 3,
  "name": "PII Shield: Real-Time Exposure Detection",
  "version": "1.0.0",
  "description": "A privacy-first extension to prevent accidental PII disclosure.",
  "permissions": ["storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"]
    }
  ],
  "icons": {
    "128": "assets/icon128.png"
  }
}