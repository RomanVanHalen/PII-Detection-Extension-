{
  "manifest_version": 3,
  "name": "PII Shield: Real-Time Exposure Detection",
  "version": "1.0.0",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "PII Shield"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-loader.js"] 
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/content-main.js",
        "src/content/ui-controller.js",
        "src/content/ui/*.js",
        "src/utils/*.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://urlhaus-api.abuse.ch/*",
    "https://api.abuseipdb.com/*"
  ]
}